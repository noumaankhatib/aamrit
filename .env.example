# ========================================================================
# Aamrit ecommerce — environment variables (copy to .env.local for dev)
# All keys are PLACEHOLDERS. Replace with real values to connect to Shopify.
# ========================================================================

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Do not set NODE_ENV in .env.local for local dev; Next.js sets it from the CLI.

# --- Shopify Storefront API ---
# Get these from your Shopify store:
# Admin → Settings → Apps and sales channels → Develop apps → Create an app
# Configure Storefront API scopes: unauthenticated_read_product_listings, 
# unauthenticated_read_product_inventory, unauthenticated_write_checkouts,
# unauthenticated_read_checkouts
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_STOREFRONT_ACCESS_TOKEN="placeholder-storefront-token"

# Public domain for client-side usage (usually same as above)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"

# Numeric shop ID from OAuth URLs, e.g. .../authentication/65906901086/oauth/...
# Or curl https://YOUR-STORE.myshopify.com/.well-known/customer-account-api (embedded in graphql_api URL path)
SHOPIFY_SHOP_ID=""

# --- Shopify Customer Account API (OAuth — hosted email / OTP sign-in) ---
# Headless or Hydrogen sales channel → Customer Account API → copy Client ID.
# Callback URL must match exactly: ${NEXT_PUBLIC_APP_URL}/api/auth/shopify-account/callback
# (HTTPS required outside localhost; use ngrok for local OAuth testing.)
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=""

# --- Shopify Admin API (for order management) ---
#
# Legacy custom app (reveal-once Admin API access token — often shpat_*):
SHOPIFY_ADMIN_ACCESS_TOKEN="placeholder-admin-token"
#
# Preferred for Dev Dashboard apps (no permanent token shown in Shopify Admin UI):
# 1. Open https://dev.shopify.com/dashboard → Apps → [your admin app]
# 2. Settings → copy Client ID and Client secret (not Catalogs keys)
# 3. Tokens are obtained automatically via OAuth client_credentials (24h TTL, cached server-side).
# Optional: SHOPIFY_ADMIN_CLIENT_ID if different from SHOPIFY_CLIENT_ID
SHOPIFY_CLIENT_ID=""
SHOPIFY_ADMIN_CLIENT_SECRET=""
SHOPIFY_ADMIN_CLIENT_ID=""

# --- NextAuth.js (Authentication) ---
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# --- Google OAuth ---
# Get these from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID, set redirect URI to: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- Admin Access ---
# Comma-separated list of email addresses that can access /admin
ADMIN_EMAILS="admin@example.com,another-admin@example.com"
